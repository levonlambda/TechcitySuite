<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".FinancingAccountListActivity">

    <!-- ========================================================================== -->
    <!-- START OF PART 1: HEADER SECTION -->
    <!-- ========================================================================== -->

    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/techcity_blue"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/backButton"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/financing_accounts"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- ========================================================================== -->
    <!-- END OF PART 1: HEADER SECTION -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 2: SEARCH BAR -->
    <!-- ========================================================================== -->

    <FrameLayout
        android:id="@+id/searchContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/searchInputLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:startIconDrawable="@drawable/ic_search"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusTopStart="8dp"
            app:boxCornerRadiusTopEnd="8dp"
            app:boxCornerRadiusBottomStart="8dp"
            app:boxCornerRadiusBottomEnd="8dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/searchEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/search_financing_accounts"
                android:inputType="text"
                android:textSize="14sp"
                android:maxLines="1" />

        </com.google.android.material.textfield.TextInputLayout>

    </FrameLayout>

    <!-- ========================================================================== -->
    <!-- END OF PART 2: SEARCH BAR -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 3: FILTER BUTTONS -->
    <!-- ========================================================================== -->

    <LinearLayout
        android:id="@+id/filterRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/white"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/searchContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/filterAllButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/filter_all"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="@color/techcity_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/filterHomeCreditButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/filter_home_credit"
            android:textSize="10sp"
            android:layout_marginEnd="4dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:backgroundTint="@color/red"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/filterSkyroButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/filter_skyro"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="@color/skyro_light_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/filterSamsungButton"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="@string/filter_samsung_finance"
            android:textSize="11sp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:backgroundTint="@color/financing_teal"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            style="@style/Widget.MaterialComponents.Button" />

    </LinearLayout>

    <!-- ========================================================================== -->
    <!-- END OF PART 3: FILTER BUTTONS -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 4: PROGRESS AND EMPTY STATE -->
    <!-- ========================================================================== -->

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:visibility="gone"
        android:indeterminateTint="@color/techcity_blue"
        app:layout_constraintTop_toBottomOf="@id/filterRow"
        app:layout_constraintBottom_toTopOf="@id/bottomSummaryBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/emptyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/no_financing_accounts"
        android:textSize="14sp"
        android:textColor="@color/gray"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/filterRow"
        app:layout_constraintBottom_toTopOf="@id/bottomSummaryBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========================================================================== -->
    <!-- END OF PART 4: PROGRESS AND EMPTY STATE -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 5: ACCOUNT LIST -->
    <!-- ========================================================================== -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/accountsRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/filterRow"
        app:layout_constraintBottom_toTopOf="@id/bottomSummaryBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========================================================================== -->
    <!-- END OF PART 5: ACCOUNT LIST -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 6: BOTTOM SUMMARY BAR -->
    <!-- ========================================================================== -->

    <LinearLayout
        android:id="@+id/bottomSummaryBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/white"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left: Total Financed -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_total_financed"
                android:textSize="11sp"
                android:textColor="@color/gray" />

            <TextView
                android:id="@+id/totalFinancedAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/techcity_blue" />

        </LinearLayout>

        <!-- Right: Entry Count -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_entries"
                android:textSize="11sp"
                android:textColor="@color/gray" />

            <TextView
                android:id="@+id/entryCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/techcity_blue" />

        </LinearLayout>

    </LinearLayout>

    <!-- ========================================================================== -->
    <!-- END OF PART 6: BOTTOM SUMMARY BAR -->
    <!-- ========================================================================== -->


    <!-- ========================================================================== -->
    <!-- START OF PART 7: FAB -->
    <!-- ========================================================================== -->

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/ic_add"
        android:contentDescription="@string/add_financing_account"
        app:backgroundTint="@color/techcity_blue"
        app:tint="@color/white"
        app:fabSize="normal"
        android:layout_marginBottom="16dp"
        android:layout_marginEnd="24dp"
        app:layout_constraintBottom_toTopOf="@id/bottomSummaryBar"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ========================================================================== -->
    <!-- END OF PART 7: FAB -->
    <!-- ========================================================================== -->

</androidx.constraintlayout.widget.ConstraintLayout>
